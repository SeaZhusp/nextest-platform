# App
APP_NAME=NexTest Platform API
ENVIRONMENT=dev
DEBUG=true
API_PREFIX=/api

# JWT
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_DAYS=1
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS / Host
# For list fields in pydantic-settings, use JSON array string.
CORS_ORIGINS=["*"]
TRUSTED_HOSTS=["*"]

# Database (MySQL async)
DATABASE_URL=mysql+asyncmy://nextest:nextest@127.0.0.1:3306/nextest?charset=utf8mb4

# Agent / 用户输入（阶段一）
AGENT_MAX_USER_TEXT_CHARS=5000
# 会话上下文：最近多少轮 user+assistant 进入 LLM（2.2.4）
AGENT_CONTEXT_MAX_ROUNDS=6
# 模型返回 JSON 数组的最少用例条数（默认 1；需更强约束时可改为 3）
AGENT_MIN_GENERATED_TEST_CASES=1
# 轻量计划执行策略（step 数、工具调用次数、单步超时）
AGENT_MAX_PLAN_STEPS=8
AGENT_MAX_TOOL_CALLS=4
AGENT_STEP_TIMEOUT_SECONDS=30
# test_case_gen 可使用更长超时；step 失败重试次数（0 表示不重试）
AGENT_STEP_TIMEOUT_SECONDS_TEST_CASE_GEN=60
AGENT_STEP_RETRY_TIMES=1
AGENT_TOTAL_TIMEOUT_SECONDS=90
# JSON string, e.g.:
# AGENT_POLICY_OVERRIDES_JSON={"roles":{"admin":{"step_retry_times":2}},"skills":{"test_case_gen":{"step_timeout_seconds":120}}}
AGENT_POLICY_OVERRIDES_JSON={}

# 技能包目录（默认 backend/skills；可改为绝对路径）
# SKILLS_DIR=/path/to/skills

# LLM（OpenAI 兼容；智能体调用使用用户在平台内保存的模型配置，不再依赖下方全局 Key）
# LLM_TIMEOUT_SECONDS=120
